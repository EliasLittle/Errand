foreign fn printf(a::Int):: Int
foreign fn free(a::Int):: Int
foreign fn strlen(a::Int):: Int
foreign fn malloc(a::Int):: Int
foreign fn strcpy(a::Int, b::Int):: Int

fn strlen(a::String)
    return strlen(as_ptr(a))
end

fn strcpy(a::String, b::String)
    return strcpy(as_ptr(a), as_ptr(b))
end

fn free(a::String)
    return free(as_ptr(a))
end

struct Point
    x::Int
    y::Int
end

fn add_one(p::Point)
    return Point(p.x+1, p.y+1)
end

fn add_one(a::Int)
    return a+1
end

fn main()
    a = Point(7, 2)
    printf("X (int): %d\n", a.x)
    printf("Y (int): %d\n", a.y)
    b = add_one(a)
    c = add_one(b)
    +-- b = a.y + 3
    return c.x
end

printf("%d\n", main())